#version 460
layout(local_size_x = 256) in;

struct PointInstance {
    vec4 position;
    vec4 color;
};

layout(set = 0, binding = 0) uniform UniformBufferObject {
    vec4 position;
    vec4 rotation;
    uint num_source_points;
    uint num_target_points;
} ubo;

layout(set = 0, binding = 1) coherent buffer SourcePointBuffer {
    PointInstance points[];
} source_point_buffer;

layout(set = 0, binding = 2) coherent buffer TargetPointBuffer {
    PointInstance points[];
} target_point_buffer;

layout(set = 0, binding = 3) coherent buffer SourceNormalBuffer {
    vec4 normals[];
} source_normal_buffer;

layout(set = 0, binding = 4) coherent buffer TargetNormalBuffer {
    vec4 normals[];
} target_normal_buffer;

layout(set = 0, binding = 5) coherent buffer OutputStorageBuffer {
    vec4 position;
    vec4 rotation;
} output_buffer;



mat3 euler_xyz_to_mat3(vec3 euler)
{
    float cx = cos(euler.x);
    float sx = sin(euler.x);

    float cy = cos(euler.y);
    float sy = sin(euler.y);

    float cz = cos(euler.z);
    float sz = sin(euler.z);

    mat3 rx = mat3(
        1.0, 0.0, 0.0,
        0.0,  cx, -sx,
        0.0,  sx,  cx
    );

    mat3 ry = mat3(
         cy, 0.0, sy,
         0.0, 1.0, 0.0,
        -sy, 0.0, cy
    );

    mat3 rz = mat3(
        cz, -sz, 0.0,
        sz,  cz, 0.0,
        0.0, 0.0, 1.0
    );

    return rz * ry * rx;
}

vec3 transform_normal_world(vec3 cloud_rotation,
                            vec3 cloud_scale,
                            vec3 local_n)
{
    mat3 R = euler_xyz_to_mat3(cloud_rotation);

    mat3 S = mat3(1.0);
    S[0][0] = cloud_scale.x;
    S[1][1] = cloud_scale.y;
    S[2][2] = cloud_scale.z;

    mat3 linear = R * S;
    mat3 normal_matrix = transpose(inverse(linear));

    return normalize(normal_matrix * local_n);
}

vec3 transform_point_world(vec3 cloud_rotation,
                           vec3 cloud_scale,
                           vec3 cloud_position,
                           vec3 local_p)
{
    mat3 R = euler_xyz_to_mat3(cloud_rotation);
    vec3 scaled = local_p * cloud_scale;
    return R * scaled + cloud_position;
}

mat3 covariance_from_normal(vec3 raw_n, float eps)
{
    float len2 = dot(raw_n, raw_n);
    if (len2 < 1e-12)
        return mat3(0.0);

    vec3 n = raw_n / sqrt(len2);
    mat3 I = mat3(1.0);
    mat3 nnT = outerProduct(n, n);

    // I - nn^T + eps * nn^T
    return I - (1.0 - eps) * nnT;
}


